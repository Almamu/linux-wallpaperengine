prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: linux-wallpaperengine-core
Description: linux-wallpaperengine backend code, handles rendering of wallpapers for the various frontends out there
Version: @PROJECT_VERSION@
Requires: glew
Libs: -L${libdir} -llinux-wallpaperengine-core
Cflags: -I${includedir}
